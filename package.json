{
  "name": "@rolster/validators",
  "version": "2.4.1",
  "type": "module",
  "description": "Utility lightweight simple for apply data validations.",
  "license": "MIT",
  "author": "Rolster Technology <rolster.developments@gmail.com>",
  "contributors": [
    {
      "name": "Daniel Andrés Castillo Pedroza",
      "email": "ing.dacastillop@gmail.com"
    }
  ],
  "types": "./dist/esm/index.d.ts",
  "main": "./dist/esm/index.js",
  "module": "./dist/esm/index.js",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "node": {
        "require": "./dist/cjs/index.js",
        "import": "./dist/esm/index.js"
      },
      "default": "./dist/esm/index.js"
    },
    "./expressions": {
      "types": "./dist/esm/expressions.d.ts",
      "node": {
        "require": "./dist/cjs/expressions.js",
        "import": "./dist/esm/expressions.js"
      },
      "default": "./dist/esm/expressions.js"
    },
    "./helpers": {
      "types": "./dist/esm/helpers.d.ts",
      "node": {
        "require": "./dist/cjs/helpers.js",
        "import": "./dist/esm/helpers.js"
      },
      "default": "./dist/esm/helpers.js"
    }
  },
  "files": [
    "dist/",
    "expressions/",
    "helpers/"
  ],
  "scripts": {
    "prettier": "prettier --write \"src/**/*.{ts}\"",
    "clean": "rimraf ./dist",
    "build": "npm run clean && tsc -p tsconfig.app.json && rollup -c rollup.config.js",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@rolster/i18n": "^2.3.1"
  },
  "devDependencies": {
    "@rolster/rollup": "^1.0.10",
    "@rolster/types": "^1.1.0",
    "@vitest/ui": "^3.2.4",
    "jsdom": "^27.0.0",
    "prettier": "^3.8.1",
    "rimraf": "^3.0.2",
    "tslib": "^2.4.0",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rolster-developments/typescript-validators.git"
  },
  "keywords": [
    "rolster",
    "typescript",
    "validators"
  ],
  "publishConfig": {
    "access": "public"
  }
}
